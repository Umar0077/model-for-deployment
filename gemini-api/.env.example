# Application Settings
APP_NAME=Gemini AI API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8001
WORKERS=1

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
# Primary model to use (will fallback to GEMINI_FALLBACK_MODEL_ID if not available)
GEMINI_MODEL_ID=gemini-2.5-flash
# Fallback model if primary model is not found
GEMINI_FALLBACK_MODEL_ID=gemini-2.5-flash-lite
GEMINI_TIMEOUT=30
GEMINI_MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60

# Security
API_KEY=your_optional_api_key_for_authentication
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
